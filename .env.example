# =====================================================================
# .env.example — landing page Salomão AI
# Copie para .env e preencha (nunca comite valores reais).
# =====================================================================

# --- Runtime ---
NODE_ENV=production
PORT=3000
TZ=America/Sao_Paulo
APP_URL=https://seudominio.com.br

# --- Contato público exibido no site ---
CONTACT_EMAIL=ga.pancione@gmail.com

# --- Notificação por e-mail (obrigatório para o e-mail funcionar) ---
LEAD_NOTIFICATION_TO=ga.pancione@gmail.com
# Preencha depois de verificar seu domínio no Resend.
LEAD_NOTIFICATION_FROM="Novos contatos <contato@seudominio.com.br>"
RESEND_API_KEY=

# --- Supabase (backend, service_role — NUNCA usar VITE_) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Webhook (opcional; deixe vazio para desativar) ---
LEAD_WEBHOOK_URL=
LEAD_WEBHOOK_SECRET=
LEAD_WEBHOOK_TOKEN=
LEAD_WEBHOOK_TIMEOUT_MS=8000

# --- Política de privacidade ---
PRIVACY_POLICY_VERSION=2026-07-01

# --- (Opcional) Chaves públicas do frontend ---
# Se o frontend usar Supabase diretamente, use apenas chaves anon/publishable:
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# --- Métricas (dashboard /metricas) ---
METRICS_TOKEN=
